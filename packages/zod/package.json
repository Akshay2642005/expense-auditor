{
  "name": "@auditor/zod",
  "version": "1.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc --build --force && tsc-alias",
    "dev": "tsc && (concurrently \"tsc -w\" \"tsc-alias -w\")",
    "clean": "rimraf dist tsconfig.tsbuildinfo .turbo node_modules"
  },
  "dependencies": {
    "@anatine/zod-openapi": "^2.2.7",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "tsc-alias": "^1.8.12",
    "typescript": "^5.8.2"
  }
}
