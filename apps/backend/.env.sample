# ============================================================================
# PRIMARY CONFIGURATION
# ============================================================================
EXPAU_PRIMARY.ENV="local"

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================
EXPAU_SERVER.PORT="8080"
EXPAU_SERVER.READ_TIMEOUT="30"
EXPAU_SERVER.WRITE_TIMEOUT="30"
EXPAU_SERVER.IDLE_TIMEOUT="60"
EXPAU_SERVER.CORS_ALLOWED_ORIGINS="http://localhost:3000"

# ============================================================================
# DATABASE & REDIS CONFIGURATION
# ============================================================================
EXPAU_DATABASE.HOST="localhost"
EXPAU_DATABASE.PORT="15432"
EXPAU_DATABASE.USER="postgres"
EXPAU_DATABASE.PASSWORD="postgres"
EXPAU_DATABASE.NAME="auditor"
EXPAU_DATABASE.SSL_MODE="disable"
EXPAU_DATABASE.MAX_OPEN_CONNS="25"
EXPAU_DATABASE.MAX_IDLE_CONNS="25"
EXPAU_DATABASE.CONN_MAX_LIFETIME="300s"
EXPAU_DATABASE.CONN_MAX_IDLE_TIME="300s"
EXPAU_REDIS.ADDRESS="localhost:16316"

# ============================================================================
# AUTH CONFIGURATION
# ============================================================================
EXPAU_AUTH.SECRET_KEY="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
EXPAU_AUTH.WEBHOOK_SECRET="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
EXPAU_INTEGRATION.RESEND_API_KEY="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
EXPAU_INTEGRATION.RESEND_FROM="Expense Auditor <onboarding@your-domain.com>"

# ============================================================================
# AI CONFIGURATION
# ============================================================================
EXPAU_AI.GEMINI_API_KEY="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
EXPAU_STORAGE.DATE_MISMATCH_THRESHOLD="7"

# ============================================================================
# STORAGE CONFIGURATION
# ============================================================================
EXPAU_STORAGE.GCS_BUCKET_NAME="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
EXPAU_STORAGE.GCS_PROJECT_ID="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
EXPAU_STORAGE.GCS_CREDENTIALS="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
EXPAU_STORAGE.GCS_MAX_FILE_SIZE_MB="10"

# ============================================================================
# OBSERVABILITY CONFIGURATION
# ============================================================================
EXPAU_OBSERVABILITY.SERVICE_NAME="expense-auditor"
EXPAU_OBSERVABILITY.ENVIRONMENT="development"

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================
EXPAU_OBSERVABILITY.LOGGING.LEVEL="debug"
EXPAU_OBSERVABILITY.LOGGING.FORMAT="console"
EXPAU_OBSERVABILITY.LOGGING.SLOW_QUERY_THRESHOLD="100ms"

# ============================================================================
# NEW RELIC CONFIGURATION
# ============================================================================
EXPAU_OBSERVABILITY.NEW_RELIC.LICENSE_KEY="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
EXPAU_OBSERVABILITY.NEW_RELIC.APP_LOG_FORWARDING_ENABLED="true"
EXPAU_OBSERVABILITY.NEW_RELIC.DISTRIBUTED_TRACING_ENABLED="true"
EXPAU_OBSERVABILITY.NEW_RELIC.DEBUG_LOGGING="false"

# ============================================================================
# HEALTH CHECKS CONFIGURATION
# ============================================================================
EXPAU_OBSERVABILITY.HEALTH_CHECKS.ENABLED="true"
EXPAU_OBSERVABILITY.HEALTH_CHECKS.INTERVAL="30s"
EXPAU_OBSERVABILITY.HEALTH_CHECKS.TIMEOUT="5s"
EXPAU_OBSERVABILITY.HEALTH_CHECKS.CHECKS="database,redis"
